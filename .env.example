# VPS deployment - copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...

# Model: haiku for prototyping, change for production sessions
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Secret token for test access outside lab sessions (use ?token=<value> in URL)
