# VPS deployment - copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...

# Model: haiku for prototyping, change for production sessions
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Secret token for test access outside lab sessions (use ?token=<value> in URL)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
TEST_TOKEN=

# Public, token-free demo mode (use ?demo=1 in URL). When "true", anyone with the
# link can try the chat; demo sessions write NOTHING to the database, are pinned to
# DEMO_MODEL, and are capped at DEMO_TURN_CAP turns. Leave OFF during data
# collection (it shares the API key/quota). Set a spend limit on the API account.
DEMO_ENABLED=false
# DEMO_MODEL=claude-haiku-4-5-20251001
# DEMO_TURN_CAP=12
