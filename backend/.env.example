# Copy this to .env and fill in your API key
ANTHROPIC_API_KEY=sk-ant-...

# Model: haiku for prototyping, override for production
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Secret token for test access outside lab sessions (?token=<value>)
# TEST_TOKEN=

# Public token-free demo mode (?demo=1). Writes nothing, cheap model, capped.
# Leave OFF during data collection. Set an API account spend limit when on.
DEMO_ENABLED=false
# DEMO_MODEL=claude-haiku-4-5-20251001
# DEMO_TURN_CAP=12
